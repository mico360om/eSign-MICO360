# eSign MICO360 backend configuration

# SQLite — zero-setup, file-based DB (default). The file is created on first migrate.
DATABASE_URL="file:./esign_mico360.db"
# To use a central PostgreSQL server instead, set e.g.:
#   DATABASE_URL="postgresql://mico:mico_secret@localhost:5432/esign_mico360?schema=public"
# and change datasource provider to "postgresql" in prisma/schema.prisma
# (converting the TEXT enum columns + permissions JSON to native types).

# API
PORT=4400
NODE_ENV=development

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# File storage (relative to server/)
STORAGE_DIR="storage"

# Optional: full path to LibreOffice 'soffice' for high-fidelity Office->PDF.
# If unset, common install locations + PATH are tried; otherwise a cover PDF is made.
# SOFFICE_PATH="C:/Program Files/LibreOffice/program/soffice.exe"

# Upload rules (overridable from System Settings in the admin portal)
MAX_FILE_SIZE_MB=25
ALLOWED_EXTENSIONS="pdf,doc,docx,xls,xlsx,ppt,pptx,png,jpg,jpeg,txt"

# CORS — comma separated origins allowed to call the API
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:3000"
