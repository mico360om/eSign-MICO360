{
  "name": "@esign-mico360/server",
  "version": "1.0.0",
  "private": true,
  "description": "eSign MICO360 backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:setup": "prisma generate && prisma migrate dev --name init",
    "db:reset": "prisma migrate reset --force",
    "seed": "tsx prisma/seed.ts",
    "smoke": "node test/smoke.mjs",
    "qa": "node test/qa.mjs",
    "qa:security": "node test/qa-security.mjs",
    "qa:features": "node test/qa-features.mjs",
    "qa:marks": "node test/qa-marks.mjs",
    "qa:types": "node test/qa-approval-types.mjs",
    "qa:reminders": "tsx test/qa-reminders.mts",
    "qa:audit": "tsx test/qa-audit-chain.mts",
    "audit:reseal": "tsx scripts/reseal-audit.mts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.22.0",
    "@signpdf/placeholder-plain": "^3.2.4",
    "@signpdf/signer-p12": "^3.2.4",
    "@signpdf/signpdf": "^3.2.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.16",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.11",
    "@types/nodemailer": "^6.4.16",
    "jimp": "^0.22.12",
    "png-to-ico": "^2.1.8",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
