// eSign MICO360 — data model
// All three clients (web / desktop / mobile) read & write through this schema.
//
// DB: SQLite (zero-setup, embeddable in the standalone desktop .exe).
// SQLite has no native enums or scalar lists, so enum-typed columns are TEXT
// and Role.permissions is a JSON string array. The allowed values live in
// src/constants.ts. To target PostgreSQL for a central multi-user server,
// switch the provider and convert these TEXT columns to enums.

generator client {
  provider = "prisma-client-js"
  // Windows-only desktop target ("native" resolves to the build machine).
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & access ───────────────────────────

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  username     String?  @unique
  passwordHash String
  phone        String?
  isActive     Boolean  @default(true)
  signatureImg String?
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  // Delegation / out-of-office, mobile push
  outOfOffice  Boolean  @default(false)
  delegateToId String?
  pushToken    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
  department   String?
  designation  String?
  forcePasswordChange Boolean @default(false)
  // Email reminders for pending items: null = use system default, 0 = off, N = every N days
  reminderFreqDays Int?
  lastReminderAt   DateTime? // when the pending-items reminder digest was last emailed

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  delegateTo   User?  @relation("Delegation", fields: [delegateToId], references: [id])
  delegatesFor User[] @relation("Delegation")

  profileLinks  ProfileMember[]
  groupLinks    SignatureGroupMember[]
  uploads       Document[]             @relation("UploadedBy")
  approvalSteps ApprovalStep[]
  notifications Notification[]
  auditLogs     AuditLog[]
  stampUsages   StampUsage[]
  savedMarks    SavedMark[]
  comments      DocumentComment[]      @relation("CommentAuthor")
  savedFilters  SavedFilter[]          @relation("SavedFilters")
}

// A named kind of approval (e.g. Approved, Reviewed, Verified). Requesters pick
// the type they want from each signatory; approvers map a saved signature to it.
model ApprovalType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  savedMarks SavedMark[]
  steps      ApprovalStep[]
}

// A user's reusable signature/initials image with preconfigured placement
// settings (default position + size), optionally tied to an approval type.
// Selected by approvers when applying.
model SavedMark {
  id        String   @id @default(cuid())
  userId    String
  label     String
  kind      String   @default("SIGNATURE") // SIGNATURE | INITIALS
  imagePath String
  posX      Float    @default(0.6) // preconfigured placement settings (normalized)
  posY      Float    @default(0.8)
  width     Float    @default(0.24)
  height    Float    @default(0.09)
  approvalTypeId String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvalType ApprovalType? @relation(fields: [approvalTypeId], references: [id], onDelete: SetNull)
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   @default("[]") // JSON string array of Permission values
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model Profile {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  thumbnailPath String? // optional profile image/logo
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members         ProfileMember[]
  signatureGroups SignatureGroup[]
  stamps          Stamp[]
  documents       Document[]
  templates       Template[]
}

// A reusable signature-request preset (profile + signatories/group + method).
model Template {
  id               String   @id @default(cuid())
  name             String
  titlePrefix      String?
  signatoryIds     String   @default("[]") // JSON array of user ids
  signatureGroupId String?
  signatureMethod  String   @default("IMAGE")
  approvalMode     String   @default("SEQUENTIAL")
  isActive         Boolean  @default(true)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProfileMember {
  id        String   @id @default(cuid())
  profileId String
  userId    String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, userId])
}

// ─────────────────────────── Signature groups ───────────────────────────

model SignatureGroup {
  id           String   @id @default(cuid())
  name         String
  description  String?
  approvalMode String   @default("SEQUENTIAL") // ApprovalMode
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  members   SignatureGroupMember[]
  documents Document[]

  @@unique([profileId, name])
}

model SignatureGroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String
  order   Int    @default(1)

  group SignatureGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// ─────────────────────────── Company stamps ───────────────────────────

model Stamp {
  id        String   @id @default(cuid())
  name      String
  imagePath String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  usages StampUsage[]
}

model StampUsage {
  id         String   @id @default(cuid())
  stampId    String
  userId     String
  documentId String?
  usedAt     DateTime @default(now())

  stamp Stamp @relation(fields: [stampId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────── Documents & workflow ───────────────────────────

model Document {
  id          String  @id @default(cuid())
  title       String
  description String?
  status      String  @default("DRAFT") // DocumentStatus

  originalPath     String?
  originalName     String?
  convertedPdfPath String?
  finalPdfPath     String?

  // Integrity & signing
  originalHash    String? // SHA-256 of the untouched original
  finalHash       String? // SHA-256 of the final signed PDF
  signatureMethod String  @default("IMAGE") // "IMAGE" | "DIGITAL"
  digitallySigned Boolean @default(false)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  uploadedById String
  uploadedBy   User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  signatureGroupId String?
  signatureGroup   SignatureGroup? @relation(fields: [signatureGroupId], references: [id])

  approvalMode String @default("SEQUENTIAL") // ApprovalMode
  priority     String @default("NORMAL")     // NORMAL | URGENT | CRITICAL
  dueDate      DateTime?
  notes        String?
  confidential Boolean @default(false)

  // Versioning — a revision links back to the previous version.
  parentId String?
  version  Int     @default(1)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  parent   Document?  @relation("Versions", fields: [parentId], references: [id])
  versions Document[] @relation("Versions")

  steps      ApprovalStep[]
  placements Placement[]
  events     DocumentEvent[]
  comments   DocumentComment[]
  tags       DocumentTag[]
}

// Tags double as folders/labels — a document can carry several; the Documents
// list filters by tag ("folder view").
model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String        @default("#8A1A1C")
  createdAt DateTime      @default(now())
  documents DocumentTag[]
}

model DocumentTag {
  documentId String
  tagId      String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
}

// A named, reusable set of Documents-list filter params, private to each user.
model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String // JSON object of filter params (status, priority, tagId, dates…)
  createdAt DateTime @default(now())

  user User @relation("SavedFilters", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Discussion thread on a document — separate from ApprovalStep.comment (the
// remark left with an approve/reject decision) and DocumentEvent (system history).
model DocumentComment {
  id         String   @id @default(cuid())
  documentId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([documentId])
}

model ApprovalStep {
  id          String    @id @default(cuid())
  documentId  String
  signatoryId String
  order       Int       @default(1)
  status      String    @default("PENDING") // StepStatus
  comment     String?
  actedAt     DateTime?
  remindedAt  DateTime? // last approval-reminder sent for this step
  approvalTypeId String? // the kind of approval the requester wants from this signatory
  createdAt   DateTime  @default(now())

  document     Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatory    User          @relation(fields: [signatoryId], references: [id])
  approvalType ApprovalType? @relation(fields: [approvalTypeId], references: [id], onDelete: SetNull)

  @@unique([documentId, signatoryId])
}

model Placement {
  id         String   @id @default(cuid())
  documentId String
  kind       String // "SIGNATURE" | "STAMP"
  page       Int      @default(1)
  x          Float
  y          Float
  width      Float
  height     Float
  imagePath  String
  placedById String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentEvent {
  id         String   @id @default(cuid())
  documentId String
  actorId    String?
  action     String
  detail     String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────── Notifications & audit ───────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // NotificationType
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  detail    String?
  ip        String?
  device    String?
  // Tamper-evident hash chain: hash = SHA-256(prevHash + canonical fields)
  prevHash  String?
  hash      String?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Auto-captured error/crash reports (server 5xx, client crashes, unhandled
// rejections) for later debugging. Viewable/exportable by admins.
model ErrorReport {
  id         String   @id @default(cuid())
  source     String // "server" | "client" | "desktop"
  message    String
  stack      String?
  url        String? // route or API endpoint
  method     String?
  status     Int?
  userId     String?
  userEmail  String?
  userAgent  String?
  appVersion String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([resolved, createdAt])
}
