{
  "name": "esign-mico360",
  "version": "1.0.0",
  "private": true,
  "description": "eSign MICO360 — digital document signature & approval management system",
  "workspaces": [
    "server",
    "web",
    "desktop",
    "mobile"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "dev:desktop": "npm --workspace desktop run dev",
    "build:server": "npm --workspace server run build",
    "build:web": "npm --workspace web run build",
    "build:desktop": "npm --workspace desktop run dist",
    "db:setup": "npm --workspace server run db:setup",
    "seed": "npm --workspace server run seed"
  },
  "engines": {
    "node": ">=20"
  }
}
