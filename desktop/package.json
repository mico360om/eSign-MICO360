{
  "name": "@esign-mico360/desktop",
  "version": "1.0.14",
  "private": true,
  "description": "eSign MICO360 Windows desktop app (self-contained Electron + embedded API + SQLite)",
  "main": "main.js",
  "author": "MICO360",
  "scripts": {
    "prepare:vendor": "node prepare.js",
    "dev": "node prepare.js && electron .",
    "dist": "node prepare.js && electron-builder --win nsis",
    "dist:mac": "node prepare.js && electron-builder --mac dmg zip --universal",
    "pack": "node prepare.js && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.mico360.esign",
    "productName": "eSign MICO360",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mico360om",
        "repo": "eSign-MICO360",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "vendor/server.js",
      "vendor/updater.js"
    ],
    "extraResources": [
      {
        "from": "vendor/runtime",
        "to": "runtime"
      },
      {
        "from": "vendor/web",
        "to": "web"
      },
      {
        "from": "vendor/migrations",
        "to": "migrations"
      },
      {
        "from": "vendor/stamp.png",
        "to": "stamp.png"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "eSign MICO360",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "darkModeSupport": false,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "x64ArchFiles": "*.node"
    },
    "dmg": {
      "title": "eSign MICO360 ${version}"
    }
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
